# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Настройки Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Настройки API (OpenAI / DeepSeek / etc)
OPENAI_API_KEY=your_api_key
# Оставьте по умолчанию для OpenAI или вставьте свой (например, DeepSeek)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Настройки RAG (эмбеддинги)
# Оставьте ПУСТЫМ для использования локальной модели (бесплатно, без API)
# Или впишите модель эмбеддингов (например, text-embedding-3-small)
OPENAI_EMBEDDING_MODEL=

# Database
DATABASE_URL=sqlite:///psychobot.db
